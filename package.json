{
  "name": "claude-ville",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "node claudeville/server.js",
    "widget:build": "cd widget && bash build.sh",
    "widget": "open widget/ClaudeVilleWidget.app",
    "sprites:validate": "node scripts/sprites/manifest-validator.mjs",
    "sprites:visual-diff": "node scripts/sprites/visual-diff.mjs",
