    "sprites:capture-fresh": "node scripts/sprites/capture-baseline.mjs --fresh"
  },
  "devDependencies": {
    "js-yaml": "^4.1.1",
    "pixelmatch": "^7.1.0",
    "playwright": "^1.59.1",
    "pngjs": "^7.0.0"
  }
}
