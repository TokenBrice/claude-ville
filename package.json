{
  "name": "claude-ville",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "node claudeville/server.js",
    "check:server": "node --check claudeville/server.js",
    "check:adapters": "node scripts/check-syntax.cjs claudeville/adapters",
    "check:services": "node scripts/check-syntax.cjs claudeville/services",
    "check:frontend-syntax": "node scripts/check-syntax.cjs claudeville/src",
    "check:scripts": "node scripts/check-syntax.cjs scripts",
    "check:git-events": "node scripts/check-git-events.cjs",
    "check:adapter-fixtures": "node scripts/adapters/validate-fixtures.cjs",
    "validate:quick": "npm run check:server && npm run check:adapters && npm run check:services && npm run check:frontend-syntax && npm run check:scripts && npm run check:git-events && npm run check:adapter-fixtures && npm run sprites:audit-ids && npm run widget:pricing-check && npm run widget:kde:check",
    "widget:build": "cd widget && bash build.sh",
    "widget": "npm run widget:build && sh -c 'app=\"widget/ClaudeVilleWidget.app\"; if [ ! -d \"$app\" ]; then echo \"widget: missing $app after build\" >&2; exit 1; fi; open \"$app\"'",
    "widget:verify-bundle": "node scripts/widget/check-bundle.cjs",
    "widget:check": "node scripts/widget/check.cjs",
    "widget:pricing-check": "node scripts/widget/check-pricing.cjs",
    "widget:kde:check": "node scripts/widget/check-kde.cjs",
    "widget:kde:install": "bash widget/kde/install.sh",
    "widget:kde:uninstall": "bash widget/kde/uninstall.sh",
    "sprites:audit-ids": "node scripts/sprites/manifest-id-audit.mjs",
    "sprites:plan": "node scripts/sprites/plan.mjs",
    "sprites:validate": "node scripts/sprites/manifest-validator.mjs",
    "sprites:visual-diff": "node scripts/sprites/visual-diff.mjs",
    "sprites:capture-baseline": "node scripts/sprites/capture-baseline.mjs",
    "sprites:capture-fresh": "node scripts/sprites/capture-baseline.mjs --fresh",
    "vendor:refresh-js-yaml": "node scripts/vendor/refresh-js-yaml.mjs"
  },
  "devDependencies": {
    "js-yaml": "^4.1.1",
    "pixelmatch": "^7.1.0",
    "playwright": "^1.59.1",
    "pngjs": "^7.0.0"
  }
}
